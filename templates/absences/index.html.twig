{# absences/index.html.twig #}

{% extends 'base.html.twig' %}

{% block specificjs %}
  <script type="text/JavaScript" src="{{ asset('js/absence.js') }}"></script>
{% endblock %}

{% block page %}
  <h3>Liste des absences</h3>
  <form name="form" id="absencesListForm" method="get" action="{{ asset('absence') }}" onsubmit="return verif_form('debut=date1;fin=date2');">
    
      <div class="row row-search mb-3">

        <label class="col-xl-auto col-form-label mt-2" for="absences-search-start">{% trans%}Start{% endtrans %} :</label>
        <div class="col-xl-auto ps-0">
          <input id="absences-search-start" type="text" name="debut" class="datepicker start-search" value="{{ debut }}"/>
        </div>

        <label class="col-xl-auto col-form-label mt-2" for="absences-search-end">{% trans%}End{% endtrans %} :</label>
        <div class="col-xl-auto ps-0">
          <input id="absences-search-end" type="text" name="fin" class="datepicker end-search" value="{{ fin }}"/>
        </div>

        {% if managed | length > 1 %}
          <div class="col-xl-2">
            <div class="row">
              <label class="col-xl-auto col-form-label mt-2" for="perso-id">{% trans%}Agent{% endtrans %} :</label>
              <select name="perso_id" id="perso_id" class="form-select form-select-sm">
                  <option value="0" {% if perso_id == 0 %} selected="selected" {% endif %}>{% trans%}Everyone{% endtrans %}</option>            
                {% for a in managed %}
                  <option value="{{ a.id }}" {% if a.id == perso_id %} selected="selected" {% endif %}>{{ a.lastname }} {{ a.firstname }}</option>
                {% endfor %}
              </select>
            </div>

            <div class="form-check-prepend">
              <label class="form-check-label" for="deleted-agent-check">{% trans%}Deleted agents{% endtrans %} :</label>              
              <input id="deleted-agent-check" type="checkbox" value="" class="form-check-input m-1 mx-2" {% if agents_deleted %} checked {% endif %} name="supprimes" onclick="updateAgentsList(this,'perso_id');"/>
            </div>
          </div>
        {% endif %}

        <div class="col-xl-3 ps-0">
          <input type="submit" role="button" value="{% trans %}Search{% endtrans %}" class="btn btn-primary m-2"/>
          <input type="button" value="{% trans %}Clear{% endtrans %}" onclick="absences_reinit();"  class="btn btn-secondary m-2" />
        </div>

        <div class="col-xl text-end">
          <a role="button" href='{{ asset("absence/add") }}' class="btn btn-primary m-2 me-0">{% trans %}Add{% endtrans %}</a>
          {% if config('AbsImport-CSV') and can_import_abs_csv %}
            <a role="button" href='{{ asset("absence/import") }}' class="btn btn-secondary m-2  ms-3 me-0">{% trans %}Import{% endtrans %}</a>
          {% endif %}
        
        </div>
      </div>
  </form>
  
  <table id='tableAbsencesVoir' class='CJDataTable' data-sort='[[1, "asc"],[2, "asc"]]'>
    <thead>
       <tr>
         <th class='dataTableNoSort'>&nbsp;</th>
         <th>Début</th>
         <th>Fin</th>
         <th id='thNom'>Agents</th>
         {% if config('Absences-validation') %}
           <th id='thValidation'>État</th>
         {% endif %}
         <th>Motif</th>
         <th>Commentaires</th>
         <th>Demande</th>
         {% if can_manage_sup_doc %}
           <th id='thPiecesJustif' class='dataTableNoSort'>
             <span style='white-space:nowrap'>Pièces justificatives</span><br/>
             <div class='absences-pj'>PJ 1</div>
             <div class='absences-pj'>PJ 2</div>
             <div class='absences-pj'>SO</div>
           </th>
         {% endif %}
         <th>Documents</th>
       </tr>
    </thead>
    <tbody>
      {% for abs in visibles_absences %}
        <tr>
          <td style='white-space: nowrap;'>
            <div class="icon-div">
              {% if abs.view_details %}
                <a href='{{ asset("absence") }}/{{ abs.id }}'>
                  <span class='pl-icon pl-icon-edit' title='Voir'></span>
                </a>
              {% endif %}
              {% if abs.rrule %}
                <span class='pl-icon pl-icon-recurring' title='Récurrence'></span>
              {% endif %}
            </div>
          </td>
          <td data-order="{{ abs.debut }}">{{ abs.debut | datefr }}</td>
          <td data-order="{{ abs.fin }}">{{ abs.fin | datefr }}</td>
          <td>{{ abs.agents | join(', ') }}</td>

          {% if config('Absences-validation') %}
            <td style="{{ abs.status_style }}">{{ abs.status }}</td>
          {% endif %}
          <td>{{ abs.motif }}</td>
          <td title="{{ abs.commentaires }}">
            <div style='height:20px;overflow:hidden;'>
              {{ abs.commentaires }}
            </div>
          </td>
          <td data-order="{{ abs.demande }}" style="white-space:nowrap;">
            {{ abs.demande | datefr }}
          </td>

          {% if can_manage_sup_doc %}
            <td style='text-align:center;'>
              <div class='absences-pj'>
                {% if abs.pj1 %}
                  <input type='checkbox' id="pj1-{{ abs.id }}" checked="checked"/>
                {% else %}
                  <input type='checkbox' id="pj1-{{ abs.id }}"/>
                {% endif %}
              </div>
              <div class='absences-pj'>
                {% if abs.pj2 %}
                  <input type='checkbox' id="pj2-{{ abs.id }}" checked="checked"/>
                {% else %}
                  <input type='checkbox' id="pj2-{{ abs.id }}"/>
                {% endif %}
              </div>
              <div class='absences-pj'>
                {% if abs.so %}
                  <input type='checkbox' id="so-{{ abs.id }}" checked="checked"/>
                {% else %}
                  <input type='checkbox' id="so-{{ abs.id }}"/>
                {% endif %}
              </div>
            </td>
          {% endif %}
          <td>
            {% for doc in abs.absdocs %}
              <a href="{{ asset("absences/document") }}/{{ doc.id }}" target='_blank' >{{ doc.filename }}</a>
              <br/>
            {% endfor %}
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>

{% endblock %}
