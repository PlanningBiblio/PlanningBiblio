{# holidayInfo/infos.html.twig #}

{% extends 'base.html.twig' %}

{% block page %}
  <div id="content-form">
    <h3>Informations sur les congés</h3>
    <div class="admin-div">
      {% if id !=0 %}
        <h4>Modification des informations sur les congés</h4>
      {% else %}
        <h4>Ajout d'une information</h4>
      {% endif %}
      <form id="form" method="post" action="{{ asset('holiday-info') }}" name="form" onsubmit="return verif_form('debut=date1;fin=date2;texte');">
        <input type="hidden" name="CSRFToken" value="{{ CSRFSession }}"/>
        <input type="hidden" name="id" value="{{ id }}"/>
        <table class="tableauFiches">
          <tr>
            <td><label>Date de début : </label></td>
            <td>
              <input type="text" name="debut" value="{{ debut }}" style="width:100%;" class="datepicker start-date" />
            </td>
          </tr>
          <tr>
            <td><label>Date de fin : </label></td>
            <td>
              <input type="text" name="fin" value="{{ fin }}" style="width:100%;" class="datepicker end-date"/>
            </td>
          </tr>
          <tr>
            <td><label>Texte : </label></td>
            <td>
              <textarea name="texte" rows="3" cols="25" class="ui-widget-content ui-corner-all emoji-picker-textarea">{{ texte }}</textarea>
            </td>
          </tr>
          <tr>
            <td>&nbsp;</td>
          </tr>
          <tr>
            <td colspan="2" style="text-align:center;">
              <a href="{{ asset('holiday-info') }}" class="btn btn-secondary" style="margin-left:30px;" role="button">
                <span>Annuler</span>
              </a>
              {% if id != 0 %}
                <a href="javascript:deleteAdminInfo({{ id }});" class="btn btn-danger" style="margin-left:30px;" role="button">
                  <span>Supprimer</span>
                </a>
              {% endif %}
              <input role="button" type="submit" value="Valider" class="btn btn-primary"/>
            </td>
          </tr>
        </table>
      </form>
    </div>
  </div>
{% endblock %}
