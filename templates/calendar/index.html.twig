{# calendar/index.html.twig #}

{% extends 'base.html.twig' %}

{% block specificjs %}
  <script type="text/JavaScript" src="{{ asset('js/calendar.js') }}"></script>
{% endblock %}

{% block page %}
  <div id="div_agenda">
    {% if agent is not null %}
      <h3> Agenda de {{ agent }} du {{ begin }} au {{ end }} </h3>
    {% else %}
      <h3>Agenda</h3>
    {% endif %}
    <div id="div_agenda_content">
    {% if agents is iterable %}
      <form name="form" id="calendar-form" method="get" action="{{ asset('calendar') }}" onsubmit="return verif_form('debut=date1;fin=date2');" novalidate>

        <div class="row row-search">

          <label class="col-xl-auto col-form-label mt-2" for="calendar-search-start">{% trans %}Start{% endtrans %} :</label>
          <div class="col-xl-auto ps-0">
            <input id="calendar-search-start" type="text" name="debut" class="datepicker form-control start-date" value="{{ begin }}"/>
          </div>

          <label class="col-xl-auto col-form-label mt-2" for="calendar-search-end">{% trans %}End{% endtrans %} :</label>
          <div class="col-xl-auto ps-0">
            <input id="calendar-search-end" type="text" name="fin" class="datepicker form-control end-date" value="{{end}}" required/>
          </div>

          {% if admin == 1 %}
            <label class="col-xl-auto col-form-label mt-2" for="agent-search">{% trans %}Agent{% endtrans %} :</label>
            <div class="col-xl-auto ps-0">
              <select name="perso_id" class="form-select form-select-sm" id="agent-search" >
                <option hidden disabled selected value=""></option>
                {% for a in agents %}
                  <option value="{{a.id}}" {% if a.id == perso_id %} selected {% endif %}> {{ a.nom }} {{ a.prenom }}</option>
                {% endfor %}
              </select>
            </div>
          {% endif %}

          <div class="col-xl-3 ps-0">
            <input type="submit" role="button" value="{% trans %}Search{% endtrans %}" class="btn btn-primary m-2"/>
          </div>

        </div>

      <div class="row">
        <div class="invalid-feedback">{% trans from 'validators' %}Please choose a valid date interval.{% endtrans %}</div>
      </div>

    </form>
    {% else %}
      Aucun agent disponible
    {% endif %}

    {% if beginSQL > endSQL  %}
    <p class="information"> La date de fin doit être supérieure à la date de début </p>
    {% elseif agent is not null and days %}
      <br/>
      <table cellpadding="10" cellspacing="0" border="0" id="tab_agenda">
        <thead>
          <tr class="center">
            <th class="ui-widget-header calendar-border ui-corner-tl" style="width : 143px;"> Lundi </th>
            <th class="ui-widget-header calendar-border" style="width : 143px;"> Mardi </th>
            <th class="ui-widget-header calendar-border" style="width : 143px;"> Mercredi </th>
            <th class="ui-widget-header calendar-border" style="width : 143px;"> Jeudi </th>
            <th class="ui-widget-header calendar-border" style="width : 143px;"> Vendredi </th>
            <th class="ui-widget-header calendar-border" style="width : 143px;"> Samedi </th>
            <th class="ui-widget-header calendar-border ui-corner-tr" style="width : 143px;"> Dimanche </th>
          </tr>
        </thead>
        <tbody>
          <tr style="height: 180px;">
            {% if cellsBefore %}
              {% for c in 1..cellsBefore %}
                <td class="cellule_grise">&nbsp;</td>
              {% endfor %}
            {% endif %}

            {% for d in days %}
              {% if d.nb is divisible by (7) %}
                {% if d.nb/7 >= 1 %}
                  </tr>
                  <tr style="height: 180px;">
                {% endif %}
              {% endif %}
              <td>
                <div class="div_date">
                    {{ d.aff | datefull(day: false, year: false) }}
                </div>
                {% if d.closed == true %}
                    <div class="ferie">
                          Bibliothèque fermée<br/><b>{{ d.name }}</b>
                    </div>
                  </td>
                {% else %}
                  {% if d.presence is not empty %}
                    <div class="attendance">
                      {% if d.presence.schedule | length > 1 %}
                        {% if nbSites > 1 %}
                          {% if d.presence.site == -1 %}
                            <p style="margin-bottom:0;"> Présence sur tous les sites : </p>
                          {% else %}
                            <p style="margin-bottom:0;"> Présence à {{ d.presence.site_name }} : </p>
                          {% endif %}
                        {% else %}
                          <p style="margin-bottom:0;"> Présence :</p>
                        {% endif %}
                        <ul>
                        {% for p in d.presence.schedule %}
                          <li> de {{ p.begin }} à {{ p.end }} </li>
                        {% endfor %}
                        </ul>
                      {% else %}
                        {% if nbSites > 1 %}
                          {% if d.presence.site == -1 %}
                            <p> Présent(e) sur tous les sites de {{ d.presence.schedule[0].begin }} à {{ d.presence.schedule[0].end }} </p>
                          {% else %}
                            <p> Présent(e) à {{ d.presence.site_name }} de {{ d.presence.schedule[0].begin }} à {{ d.presence.schedule[0].end }} </p>
                          {% endif %}
                        {% else %}
                          <p> Présent(e) de {{ d.presence.schedule[0].begin }} à {{ d.presence.schedule[0].end }} </p>
                        {% endif %}
                      {% endif %}
                    </div>
                  {% endif %}
                  {% if d.absence is not empty %}
                    <div class ="important">
                      {% if d.absence | length == 1 %}
                        <p class="calendar-absence"> Absence : </p>
                      {% elseif d.absence | length > 1 %}
                        <p class="calendar-absence"> Absences : </p>
                      {% endif %}
                      <ul>
                      {% for a in d.absence %}
                        <li> {{ a }} </li>
                      {% endfor %}
                      </ul>
                    </div>
                  {% endif %}
                  {% if d.position is not empty %}
                    <div class ="postes">Postes occupés :
                      <ul>
                      {% for position in d.position  %}
                        {% if position.absent == true %}
                          <li style="text-decoration: line-through;" class="important">
                        {% else %}
                          <li>
                        {% endif %}
                        {{ position.hour }} {{ position.name }} </li>
                      {% endfor %}
                      </ul>
                    </div>
                  {% endif %}
                {% endif %}
            {% endfor %}
            {% if cellsAfter %}
              {% for c in 1..cellsAfter %}
                <td class="cellule_grise">&nbsp;</td>
              {% endfor %}
            {% endif %}
          </tr>
        </tbody>
      </table>
    {% endif %}
    </div>
  </div>

{% endblock %}
