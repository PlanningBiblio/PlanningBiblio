{# myAccount.html.twig #}

{% extends 'base.html.twig' %}

{% block page %}
{% include 'agents/elements/change_password.html.twig' %}

    <!--	Menu	-->
    <h3>Mon Compte</h3>

    <div class="container-tabs">
      <ul class="nav nav-tabs" role="tablist">

        {% if config('PlanningHebdo') %}
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="working_hours-tab" data-bs-toggle="tab" data-bs-target="#working_hours" type="button" role="tab" aria-controls="working_hours" aria-selected="true">
              {% trans %}My office hours{% endtrans %}
            </button>
          </li>
        {% endif %}

        {% if config('Conges-Enable') %}
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="credits-tab" data-bs-toggle="tab" data-bs-target="#credits" type="button" role="tab" aria-controls="credits" aria-selected="false">
              {% trans %}My credits{% endtrans %}
            </button>
          </li>
        {% endif %}

         {% if ics %}
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="ics-tab" data-bs-toggle="tab" data-bs-target="#ics" type="button" role="tab" aria-controls="ics" aria-selected="false">
              {% trans %}ICS Calendars{% endtrans %}
            </button>
          </li>
        {% endif %}

        <li class="nav-item" role="presentation">
          <button class="nav-link" id="motDePasse-tab" data-bs-toggle="tab" data-bs-target="#motDePasse" type="button" role="tab" aria-controls="motDePasse" aria-selected="false">
            {% trans %}My password{% endtrans %}
          </button>
        </li>
      </ul>

      <div class="tab-content">

      {% if config('PlanningHebdo') %}
        <!-- Working hours -->
        <div class="tab-pane fade show active m-4" id="working_hours" role="tabpanel" aria-labelledby="working_hours-tab" tabindex="0">
          <div class="row">
            <div class="col">
              <h3>Heures de présence</h3>
            </div>
            {% if config('PlanningHebdo-Agents') %}
              <div class="col" style="text-align: end;">
                <a role="button" href="{{ asset ('workinghour/add') }}?retour=/myaccount" class="btn btn-primary">Entrer de nouveaux horaires</a>
              </div>
            {% endif %}
          </div>

          <!-- Working hours history -->
          <div id='historique'>
            <br/>
            <table id='tablePresenceMonCompte' class='CJDataTable' data-sort='[[1],[2],[3]]'>
              <thead>
                <tr id="account">
                  <th class='dataTableNoSort'>&nbsp;</th>
                  <th class='dataTableDateFR'>Début</th>
                  <th class='dataTableDateFR'>Fin</th>
                  <th class='dataTableDateFR'>Saisie</th>
                  <th>Validation</th>
                  <th>Actuel</th>
                  <th>Commentaires</th>
                </tr>
              </thead>
              <tbody>
                {% for elem in planning %}
                  <tr>
                    <td style='white-space:nowrap;'>{{ elem.remplace ? "<font style='font-size:20pt;'>&rdsh;</font>": "" }}
                      <a href="{{ asset('workinghour') }}/{{ elem.id }}?retour=/myaccount"/>
                        <span class='pl-icon pl-icon-edit' title='Voir'></span>
                      </a>
                    </td>
                    <td>{{ elem.debut }}</td>
                    <td>{{ elem.fin }}</td>
                    <td>{{ elem.saisie }}</td>
                    <td>{{ elem.validation }}</td>
                    <td>{{ elem.actuel ? "Oui" : ""}}</td>
                    <td>{{ elem.commentaires }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div> <!-- Historique' -->
        </div> <!-- working_hours -->
      {% endif %}
      
      {% if config('Conges-Enable') %}
        <!-- Crédits -->
        <div class="tab-pane fade m-4" id="credits" role="tabpanel" aria-labelledby="credits-tab" tabindex="0">
          <h3>Crédits</h3>
          <table class='tableauFiches'>
            <tr>
              <td style='font-weight:bold;' colspan='2'>Congés</td>
            </tr>
            <tr>
              <td>Crédit annuel</td>
              {% if config('Conges-Mode') == 'heures' %}
                <td style='text-align:right;'>
                  {{ credits.annuel }}
                </td>
              {% endif %}
              {% if config('Conges-Mode') == 'jours' or show_hours_to_days %}
              <td style='text-align:right;'>
                {{ credits.joursAnnuel }}
              </td>
              {% endif %}
            </tr>
            <tr>
              <td>Crédit restant</td>
              {% if config('Conges-Mode') == 'heures' %}
                <td style='text-align:right;'>
                  {{ credits.conges }}
                </td>
              {% endif %}

              {% if config('Conges-Mode') == 'jours' or show_hours_to_days %}
                <td style='text-align:right;'>
                  {{ credits.joursConges }}
                </td>
              {% endif %}
            </tr>
            <tr>
              <td>Reliquat</td>
              {% if config('Conges-Mode') == 'heures' %}
                <td style='text-align:right;'>
                  {{ credits.reliquat }}
                </td>
              {% endif %}
              {% if config('Conges-Mode') == 'jours' or show_hours_to_days %}
                <td style='text-align:right;'>
                  {{ credits.joursReliquat}}
                </td>
              {% endif %}
            </tr>
            <tr>
              <td>Solde débiteur</td>
              {% if config('Conges-Mode') == 'heures' %}
                <td style='text-align:right;'>
                  {{ credits.anticipation }}
                </td>
               {% endif %}
               {% if config('Conges-Mode') == 'jours' or show_hours_to_days %}
                 <td style='text-align:right;'>
                   {{ credits.joursAnticipation }}
                 </td>
               {% endif %}
            </tr>
            <tr>
              <td style='font-weight:bold;padding-top:20px;' colspan='2'>Récupérations</td>
            </tr>
            <tr>
              <td>Crédit</td>
              <td style='text-align:right;'>
                {{ credits.recuperation }}
              </td>
            </tr>
          </table>
          {% if show_hours_to_days %}
            <p style='font-style:italic;margin:30px 0 0 10px;'>Le nombre de jours est calculé sur la base de {{ hours_per_day }} heures par jour.</p>
          {% endif %}
        </div>
      <!-- Crédits-->
      {% endif %}

      <!-- Mot de Passe -->
      <div class="tab-pane fade m-4" id="motDePasse" role="tabpanel" aria-labelledby="motDePasse-tab" tabindex="0">
        <h3>Changement de mot de passe</h3>
        {% include 'agents/elements/change_password_div.html.twig' %}
      </div> <!-- motDePasse -->

      <!-- Agendas ICS -->
      <div class="tab-pane fade m-4" id="ics" role="tabpanel" aria-labelledby="ics-tab" tabindex="0">
        <h3>Agendas ICS</h3>
        <p>
          <ul>
            <li>Agenda des plages de service public : 
              <span id='urlIcs'><a style="color:#29495C;" href='{{ config('URL') }}{{ ics }}'>{{ config('URL') }}{{ ics }}</a></span>
            </li>
            <li>Agenda des plages de service public et des absences : 
              <span id='urlIcsWithAbsences'><a style="color:#29495C;" href='{{ config('URL') }}{{ ics }}&absences=1'>{{ config('URL') }}{{ ics }}&absences=1</a></span>
            </li>
          </ul>
          {% if config('ICS-Code') %}
          <br/><a style="font-size: 15px;margin-top: 30px; color:#29495C;" href="javascript:resetICSURL({{ login.id }});"> Réinitialiser les URL</a>
          {% endif %}
        </p>
      </div> <!-- Agendas ICS -->

      </div> <!-- tab-content -->
    </div> <!-- nav-tabs -->
{% endblock %}
