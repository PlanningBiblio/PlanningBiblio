{# agents/rights.html.twig #}

<div class="tab-pane fade" id="access" role="tabpanel" aria-labelledby="access-tab" tabindex="0">
  <ul>
    {% for category, elem in rights %}
      <h3 style='margin:10px 0 5px 0;'>{{ category }}</h3>
      {% for right in elem.rights %}
        <li>
          {% if right.checked %}
            {{ right.groupe }}<label class='agent-acces-checked2 green fw-bold'>Oui</label>
          {% else %}
            {{ right.groupe }}<label class='agent-acces-checked2 red'>Non</label>
          {% endif %}
        </li>
      {% endfor %}
    {% endfor %}
  </ul>

  {% if config('Multisites-nombre') > 1 %}
    <table style='margin-top:50px;'>
      <thead>
        <tr>
          <th>&nbsp;</th>
          {% for s in sitesSelect %}
            <th class="text-center px-3">{{ s.name }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for category, elem in rights_sites %}
          <tr>
            <td>
              <h3 style='margin:10px 0 5px 0;'>{{ category }}</h3>
            </td>
          </tr>
          {% for right in elem.rights %}
            <tr>
              <td>{{ right.groupe }}</td>
              {% for s in right.sites %}
                {% if s.checked %}
                  <td class='text-center green fw-bold'>Oui</td>
                {% else %}
                  <td class='text-center red'>Non</td>
                {% endif %}
              {% endfor %}
            </tr>
          {% endfor %}
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
</div>
