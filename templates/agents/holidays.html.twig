{# agents/holidays.html.twig #}

<div class="tab-pane fade" id="conges" role="tabpanel" aria-labelledby="conges-tab" tabindex="0">
  <table class='tableauFiches'>
    <tr>
      <td>Nombre de jours de congés par an :</td>
      <td class="text-end">
        {% if can_manage_agent %}
          <input type="number" name="conges_annuel" step="0.5" style="width:60px;" value="{{ annuel_heures }}">
          <label class="text-center p-1">jour(s)</label>
        {% else %}
          {{ annuel_string }} jour(s)
        {% endif %}
      </td>
    </tr>

    <tr>
      <td>Crédit de congés actuel :</td>
      <td class="text-end">
        {% if can_manage_agent %}
          <input type='number' name="conges_credit" step="0.5" value='{{ credit_heures}}'  style='width:60px;'>
          <label class="text-center p-1">jour(s)</label>
        {% else %}
          {{ credit_string }} jour(s)
        {% endif %}
      </td>
    </tr>

    <tr>
      <td>Reliquat de congés :</td>
      <td class="text-end">
        {% if can_manage_agent %}
          <input type='number' name='conges_reliquat' step="0.5" value='{{ reliquat_heures}}'  style='width:60px;'>
          <label class="text-center p-1">jour(s)</label>
        {% else %}
          {{ reliquat_string }} jour(s)
        {% endif %}
      </td>
    </tr>

    <tr>
      <td>Solde débiteur :</td>
      <td class="text-end">
        {% if can_manage_agent %}
          <input type='number' name='conges_anticipation' step="0.5" value='{{ anticipation_heures}}'  style='width:60px;'>
          <label class="text-center p-1">jour(s)</label>
        {% else %}
          {{ anticipation_string }} jour(s)
        {% endif %}
      </td>
    </tr>

    <tr>
      <td>{{ lang_comp_time }} :</td>
      <td class="text-end" style='padding-right: 45px;'>
        {% if can_manage_agent %}
          <input type='text' name='comp_time_hours' id='comp_time_hours' value='{{ recup_heures }}' class="text-end" style='width:60px;'>
          <label class="text-center p-1">h</label>
          <input type='text' name='comp_time_min' id='comp_time_min' value='{{ recup_min | digit(2) }}' class="text-start" style='width:60px;'>
        {% else %}
          <p style='padding-right: 18px;'>
          {{ recup_heures }}h{{ recup_min | digit(2) }}
          </p>
        {% endif %}
      </td>
    </tr>
  </table>
</div>
