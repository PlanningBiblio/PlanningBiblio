{# agents/edit.html.twig #}

{% extends 'base.html.twig' %}

{% block page %}
  <script type="text/JavaScript">
    <!--
    complet = JSON.parse('{{ postes_completNoms_json | e('js') }}');
    -->
    $( document ).ready(function() {
      $("#reset-login-form").dialog({
        autoOpen: false,
        height: 180,
        width: 380,
        modal: true,
        buttons: {
          Enregistrer: function() {
            $('#login-duplicate').hide();
            $('#login-empty').hide();
            $('#login-identic').hide();

            login = $('#new_login').val();
            agent_id = $('input[name="id"]').val();

            if (login == '') {
              $('#login-empty').show();
            } else {
              $.ajax({
                url: url('ajax/update_agent_login'),
                type: "POST",
                dataType: "html",
                data: {_token: $('#_token').val(), login: login, id: agent_id},
                success: function(filtered_login){
                    $("#reset-login-form").dialog( "close" );
                    $('#login').html(filtered_login);
                },
                error: function(xhr, ajaxOptions, thrownError){
                  if (xhr.responseText == 'duplicate') {
                    $('#login-duplicate').show();
                  } else if (xhr.responseText == 'identic') {
                    $('#login-identic').show();
                  } else {
                    information("Une erreur est survenue lors de la modification du login.","error");
                    $(this).dialog( "close" );
                  }
                }
              });
            }
          },
          Annuler: function() {
            $(this).dialog( "close" );
          },
        },
      });

      $('#change-login-link').on('click', function() {
        $('#login-duplicate').hide();
        $('#login-empty').hide();
        $('#login-identic').hide();
        $('#new_login').val('');
        $('#reset-login-form').dialog('open');
      });
    });
  </script>
  <h3>
    {% if id %}
      {{ agent.lastname }} {{ agent.firstname }}
    {% else %}
      Ajout d'un agent
    {% endif %}
  </h3>

  <div class="ui-tabs">
    <ul>
      <li id="admin"><a href="#main">Infos générales</a></li>

      {% if not config('Planook') %}
        <li id="admin"><a href="#qualif">Activités</a></li>
      {% endif %}

      <li id="admin"><a href="#temps" id="personnel-a-li3">Heures de présence</a></li>

      {% if showAgendasAndSync %}
        <li id="admin"><a href="#agendas">Agendas et Synchronisation</a></li>
      {% endif %}

      {% if config('Conges-Enable') %}
        <li id="admin"><a href="#conges">Congés</a></li>
      {% endif %}

      <li id="admin"><a href="#access">Droits d'accès</a></li>

      {% if can_manage_agent %}
        <li id="admin" class="ui-tab-cancel"><a href="{{ asset('agent') }}">Annuler</a></li>
        <li id="admin" class="ui-tab-submit"><a id="post_form_agent" href="">Valider</a></li>
      {% else %}
        <li id="admin" class="ui-tab-cancel"><a href="{{ asset('agent') }}">Fermer</a></li>
      {% endif %}
    </ul>

    <form method="post" action="{{ asset('agent') }}" name="form">
      <input type="hidden" name="_token" value="{{ csrf_token('') }}"/>

      <div id="main" style="margin-left:70px;padding-top:30px;">
        <input type="hidden" value="{{ action }}" name="action" />
        <input type="hidden" value="{{ id }}" name="id" />

        {% if can_manage_agent %}
          {% include 'agents/agent_table_edit.html.twig' %}
        {% else %}
          {% include 'agents/agent_table.html.twig' %}
        {% endif %}
      </div>

      {% if not config('Planook') %}
        <div id="qualif" style="margin-left:70px;display:none;padding-top:30px;">
          {% if can_manage_agent %}
            {% include 'agents/skills_edit.html.twig' %}
          {% else %}
            {% include 'agents/skills.html.twig' %}
          {% endif %}
        </div>
      {% endif %}

      <div id="temps" style="display:none;padding-top:30px;">
        {# raw is needed because hours_tab contains html (see hours_tables.php) #}
        {{ hours_tab | raw }}
      </div>

      <div id="agendas" style="margin-left:70px;display:none;padding-top:30px;">
        <table style="width:90%;">
          {% if config('Hamac-csv') %}
            <tr>
              <td style="width:400px">Synchronisation {{ config('Hamac-motif') ?? 'Hamac' }} :</td>
              <td>
                {% if can_manage_agent %}
                  <input type="checkbox" value="1" name="check_hamac" {% if agent.hamacCheck %} checked="checked" {% endif %}/>
                {% else %}
                  {% if agent.hamacCheck %}
                    <span class="agent-acces-checked2 green bold">Oui</span>
                  {% else %}
                    <span class="agent-acces-checked2 red">Non</span>
                  {% endif %}
                {% endif %}
              </td>
            </tr>
          {% endif %}

          {% if config('ICS-Server1') %}
            <tr>
              <td style="width:400px">Synchronisation de l"agenda ICS {{ config('ICS-Pattern1') ?? 'Serveur ICS N°1' }} :</td>
              <td>
                {% if can_manage_agent %}
                  <input type="checkbox" value="1" name="check_ics1" {% if agent.icsCheck[0] %} checked="checked" {% endif %}/>
                {% else %}
                  {% if agent.icsCheck[0] %}
                    <span class="agent-acces-checked2 green bold">Oui</span>
                  {% else %}
                    <span class="agent-acces-checked2 red">Non</span>
                  {% endif %}
                {% endif %}
              </td>
            </tr>
          {% endif %}

          {% if config('ICS-Server2') %}
            <tr>
              <td style="width:400px">Synchronisation de l'agenda ICS {{ config('ICS-Pattern2') ?? 'Serveur ICS N°2' }} :</td>
              <td>
                {% if can_manage_agent %}
                  <input type="checkbox" value="1" name="check_ics2" {% if agent.icsCheck[1] %} checked="checked" {% endif %}/>
                {% else %}
                  {% if agent.icsCheck[1] %}
                    <span class="agent-acces-checked2 green bold">Oui</span>
                  {% else %}
                    <span class="agent-acces-checked2 red">Non</span>
                  {% endif %}
                {% endif %}
              </td>
            </tr>
          {% endif %}

          {% if config('ICS-Server3') %}
            <tr>
              <td style="width:400px">Synchronisation de l'agenda ICS {{ config('ICS-Pattern3') ?? 'Serveur ICS N°3' }} :</td>
              <td>
                {% if can_manage_agent %}
                  <input type="checkbox" value="1" name="check_ics3" {% if agent.icsCheck[2] %} checked="checked" {% endif %}/>
                  <input type="text" value="{{ agent.icsUrl }}" name="url_ics" style="width:400px; margin-left:20px;" />
                {% else %}
                  {% if agent.icsCheck[2] %}
                    <span class="agent-acces-checked2 green bold">Oui</span>
                  {% else %}
                    <span class="agent-acces-checked2 red">Non</span>
                  {% endif %}
                  <span style="margin-left:20px;">{{ agent.icsUrl }}</span>
                {% endif %}
              </td>
            </tr>
          {% endif %}

          {% if id and exportIcsUrl %}
            <tr>
              <td style="padding-top: 20px;">Agenda Planno des plages de service public</td>
              <td style="padding-top: 20px;" id="urlIcs"><a href="{{ config('URL') }}{{ exportIcsUrl }}">{{ config('URL') }}{{ exportIcsUrl }}</a></td>
            </tr>

            <tr>
              <td>Agenda Planno des plages de service public et des absences</td>
              <td id="urlIcsWithAbsences"><a href="{{ config('URL') }}{{ exportIcsUrl }}&absences=1">{{ config('URL') }}{{ exportIcsUrl }}&absences=1</a></td>
            </tr>

            {% if config('ICS-Code') %}
              <tr>
                <td style="padding-top:20px;">&nbsp;</td>
                <td style="padding-top:20px;">
                  <a href="javascript:resetICSURL('{{ id }}', '{{ agent.firstName }} {{ agent.lastName }}');">
                    Réinitialiser les URL des agendas Planno
                  </a>
                </td>
              </tr>
            {% endif %}
              <tr>
                <td>&nbsp;</td>
                <td>
                  <a href="javascript:sendICSURL();">
                    Envoyer les URL à l'agent par e-mail ({{ agent.mail }})
                  </a>
                </td>
              </tr>
          {% endif %}

          {% if config('MSGraph-ClientID') %}
            <tr>
              <td style="width:400px;">
                <label for="MSGraph">Synchronisation de l'agenda Office 365 :</label>
              </td>
              <td>
                {% if can_manage_agent %}
                  <input type="checkbox" value="1" id="MSGraph" name="MSGraph" {% if agent.msGraphCheck %} checked="checked" {% endif %} />
                {% else %}
                  {% if agent.msGraphCheck %}
                    <span class="agent-acces-checked2 green bold">Oui</span>
                  {% else %}
                    <span class="agent-acces-checked2 red">Non</span>
                  {% endif %}
                {% endif %}
              </td>
            </tr>
          {% endif %}

        </table>
      </div>

      {% if can_manage_agent %}
        {% include 'agents/rights_edit.html.twig' %}
      {% else %}
        {% include 'agents/rights.html.twig' %}
      {% endif %}

      {% if config('Conges-Enable') %}
        {% if config('Conges-Mode') == 'heures' %}
          {% include 'agents/holidays_hours.html.twig' %}
        {% else %}
          {% include 'agents/holidays.html.twig' %}
        {% endif %}
      {% endif %}
    </form>
  </div>

  <div class="modal modal-lg noprint" id="add-status-modal" data-bs-backdrop="static" tabindex="-1" aria-labelledby="add-status-title" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="add-status-title">Liste des statuts</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          
          <p class="validateTips">Ajoutez, supprimez des statuts et modifiez l'ordre générale dans le menu déroulant.</p>
          <form id="add-status">
            <div class="row">
              <div class="col-5 ps-0">
                <input type="text" id="add-status-text" class="form-control form-control-sm mb-0" style="width:100%;" required>
                <div class="invalid-feedback ms-3" id="invalid-status">Statut invalide</div>
              </div>
              <div class="col-1">
                <button type="submit" id="add-status-button" class="btn btn-primary m-2 mb-0">Ajouter</button>
              </div>
            </div>
          </form>

          <div class="row row-header rounded-top-1 m-0 mt-2">
            <i class="col-auto p-2 bi bi-arrow-down-up" aria-hidden="true"></i>
            <span class="col-6 ps-0">Nom</span>
            <span class="col-4" >Catégorie</span>
          </div>

          <form id="arrange-statuses">
            <fieldset class="container-fluid">

              <ul id="statuses_sortable">
                {% if statuts is iterable %}
                  {% for s in statuts %}

                  <li class="row row-sortable" id="li_{{ s.id }}">
                      <i class="col-auto p-0 ps-2 bi bi-arrow-down-up"></i>
                      <span class="col-6 p-2" id="valeur_{{ s.id}}">{{ s.value }}</span>
                      <div class="col-4">
                        <select id="categorie_{{ s.id }}" class="form-control form-select form-select-sm" aria-label="Séléction Catégorie">
                          {% for c in categories %}
                            <option value="{{c.id }}"  {% if c.id == s.category %} selected="selected" {% endif %} >{{ c.value }}</option>
                          {% endfor %}
                        </select>
                      </div>

                      {% if s.value not in statuts_utilises %}
                        <span class="col-1 ps-5" onclick="$(this).closest('li').hide();">
                          <i class="bi bi-trash3-fill"></i>
                        </span>
                      {% endif %}
                  </li>

                  {% endfor %}
                {% endif %}
              </ul>
            </fieldset>
          </form>
        </div>

        <div class="modal-footer">
          <button type="submit" class="btn btn-primary" form="arrange-statuses">Enregister</button>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        </div>

      </div>
    </div>
  </div>

  <div class="modal modal-lg noprint" id="add-service-modal" data-bs-backdrop="static" tabindex="-1" aria-labelledby="add-service-title" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="add-service-title">Liste des services</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          
          <p class="validateTips">Ajoutez, supprimez des services et modifiez l'ordre générale dans le menu déroulant.</p>
          <form id="add-service">
            <div class="row">
              <div class="col-5 ps-0">
                <input type="text" id="add-service-text" class="form-control form-control-sm mb-0" style="width:100%;" required>
                <div class="invalid-feedback ms-3" id="invalid-service">Service invalide</div>
              </div>

              <div class="col-1">
                <button type="submit" id="add-service-button" class="col-1 btn btn-primary m-2 mb-0">Ajouter</button>
              </div>
            </div>
          </form>

          <div class="row row-header rounded-top-1 m-0 mt-2">
            <i class="col-auto p-2 bi bi-arrow-down-up" aria-hidden="true"></i>
            <span class="col-10 ps-0">Nom</span>
          </div>

          <form id="arrange-services">
            <fieldset class="container-fluid">

              <ul id="services_sortable">
              {% if services is iterable %}
                {% for s in services %}

                  <li class="row row-sortable" id="li_{{ s.id }}">
                      <i class="col-auto p-0 ps-2 bi bi-arrow-down-up"></i>
                      <span class="col-10 p-2" id="valeur_{{ s.id}}">{{ s.value }}</span>
                      {% if s.value not in services_utilises %}
                        <span class="col-1 ps-5" onclick="$(this).closest('li').hide();">
                          <i class="bi bi-trash3-fill"></i>
                        </span>
                      {% endif %}
                  </li>
                  {% endfor %}
                {% endif %}
              </ul>
            </fieldset>
          </form>
        </div>

        <div class="modal-footer">
          <button type="submit" class="btn btn-primary" form="arrange-services">Enregister</button>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        </div>

      </div>
    </div>
  </div>

  <div id="ics-url-form" title="Envoi des URL des agendas Planno" class="noprint" style="display:none;">
    <p class="validateTips">Envoyez à l'agent les URL de ses agendas Planno.</p>
    <form>
      <strong>Destinataire</strong><br/>
      <span id="ics-url-recipient">&nbsp;</span><br/><br/>
      <label for="ics-url-subject">Sujet</label><br/>
      <input type="text" id="ics-url-subject" name="ics-url-subject" value="{{ lang_send_ics_url_subject }}"/><br/><br/>
      <label for="ics-url-text">Message</label><br/>
      <textarea id="ics-url-text" name="ics-url-text">{{ lang_send_ics_url_message }}</textarea>
    </form>
  </div>

  <script type="text/JavaScript">
    {% if config('EDTSamedi') %}
      $("#EDTTabs").tabs();
    {% endif %}
    {% for i in 0..config('nb_semaine') %}
      $(".select{{ i }}").change(function(){calculHeures($(this),"","form","heures{{ i }}",{{ i }});});
      $("document").ready(function(){calculHeures($(this),"","form","heures{{ i }}",{{ i }});});
    {% endfor %}
  </script>
  <script type="text/JavaScript" src="{{ asset('js/agent.js') }}"></script>

{% endblock %}
