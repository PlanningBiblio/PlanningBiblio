{# workinghour/index.html.twig #}

{% extends 'base.html.twig' %}

{% block page %}

  <h3>Heures de présence</h3>
  <div id="buttons">
    <form class="needs-validation" name="form" method="get" action="{{ asset('workinghour') }}" onsubmit="return plHebdoVerifForm();" id="search-presence-form">
      <div class="row">
        <div class="col-lg-3">
          <label class="form-label" for=".datepicker.d">Début :</label>
          <input type="text" name="debut" id="" class="datepicker form-control d" value="{{ debut }}" placeholder="jj/mm/aaaa"/>
          <div class="invalid-feedback">La date de début doit être inférieure à la date de fin.</div>
        </div>

        <div class="col-lg-3">
          <label class="form-label" for=".datepicker.f">Fin :</label>
          <input type="text" name="fin" class="datepicker form-control f" value="{{ fin }}" placeholder="jj/mm/aaaa"/>
          <div class="invalid-feedback">La date de fin doit être supérieure à la date de début.</div>
        </div>
        
        <div class="col-lg-3">
        <input id="submit-search" type="submit" role="button" value="Rechercher" class="btn btn-secondary m-2"/>
        <input type="button" value="Réinitialiser" onclick="location.href='{{ asset('workinghour') }}?reset=on'" class="btn btn-secondary m-2" />        
        {%if admin and config('PlanningHebdo-resetCycles') and config('nb_semaine') > 2 %}
          <a role="button" class="btn btn-secondary m-2" href="{{ path('workinghour.settings') }}" >Paramètres</a>
        {% endif %}
        </div>

        <div class="col-lg-3 text-end">
          <a class="btn btn-primary m-2 me-0" role="button" href="{{ asset('workinghour') }}/add?retour={{ asset('workinghour') }}">Entrer de nouveaux horaires</a>
        </div>
      </div>
    </form>
  </div>
  <br/>
  <table id='tablePlanningHebdo' class='CJDataTable' data-sort='[[3],[4],[1]]'>
    <thead>
      <tr>
        <th rowspan='2' class='dataTableNoSort'>&nbsp;</th>
        <th colspan='2'>Agent</th>
        <th rowspan='2'>Service</th>
        <th rowspan='2' class='dataTableDateFR'>Début</th>
        <th rowspan='2' class='dataTableDateFR'>Fin</th>
        <th rowspan='2' class='dataTableDateFR'>Saisie</th>
        <th colspan='2'>Validation</th>
        <th rowspan='2'>Actuel</th>
        <th rowspan='2'>Commentaires</th>
      </tr>
      <tr>
        <th>Nom</th>
        <th>Prénom</th>
        <th>État</th>
        <th class='dataTableDateFR' style="border-right: 1px solid #000;">Date</th>
      </tr>
    </thead>
    <tbody>
      {% for elem in tab %}
        <tr id='tr_{{ elem.id }}'>
          <td style='white-space:nowrap;'>
            {{ (elem.remplace != 0) ? "<font style='font-size:20pt;'>&rdsh;</font>": " " }}
            <a href="{{ asset('workinghour')}}/{{ elem.id }}?retour={{ asset("workinghour") }}"/>
              <span class='pl-icon pl-icon-edit' title='Voir'></span>
            </a>
            {% if elem.cle == null and admin %}
              <a href='{{ asset('workinghour') }}/{{ elem.id }}?copy={{ elem.id }}&retour={{ asset("workinghour") }}'/>
                <span class='pl-icon pl-icon-copy' title='Copier'></span>
              </a>
              <a href='javascript:plHebdoSupprime({{ elem.id }});' style='margin-left:6px;'/>
                <span class='pl-icon pl-icon-dropblack' title='Supprimer'></span>
              </a>
            {% endif %}
          </td>
          <td>{{ elem.surname }}</td>
          <td>{{ elem.firstname }}</td>
          <td>{{ elem.service }}</td>
          <td>{{ elem.debut }}</td>
          <td>{{ elem.fin }}</td>
          <td>{{ elem.saisie }}</td>
          <td {{ (elem.valide >= 0) ? " " : "class='red'"}} >{{ elem.validation }}</td>
          <td {{ (elem.valide >= 0) ? " " : "class='red'"}} >{{ elem.validation_date }}</td>
          <td>{{ (elem.actuel != 0) ? "Oui" : " "}}</td>
          <td>{{ elem.commentaires | nl2br }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
{% endblock %}
{% block specificjs %}
  <script type="text/javascript" src="{{ asset('js/workingHour.js') }}"></script>
{% endblock %}
